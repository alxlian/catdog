---
import Background from '../components/Background.astro';
import '../styles/global.css';

import citywide from '../data/citywide.json';
import breedList from '../data/breed-list.json';
import names from '../data/names.json';
import breedTrends from '../data/breed-trends.json';

const totalDogs = citywide.species_split.DOG.toLocaleString();
const totalCats = citywide.species_split.CAT.toLocaleString();
const uniqueBreeds = new Set(breedList.map((e: any) => e.breed)).size;

let lunaCount = 0;
for (const species of Object.values(names) as any[]) {
  if (species['LUNA']) {
    for (const entry of species['LUNA']) {
      lunaCount += entry.count;
    }
  }
}

// Licensing stats for blurb
const yearlyTotals: Record<number, { DOG: number; CAT: number }> = {};
for (const species of ['DOG', 'CAT'] as const) {
  const breeds = (breedTrends as any)[species] || {};
  for (const entries of Object.values(breeds) as any[]) {
    for (const e of entries) {
      if (!yearlyTotals[e.year]) yearlyTotals[e.year] = { DOG: 0, CAT: 0 };
      yearlyTotals[e.year][species] += e.count;
    }
  }
}
const years = Object.keys(yearlyTotals).map(Number).sort();
const firstYear = years[0];
const lastFullYear = years[years.length - 2];
const firstTotal = yearlyTotals[firstYear].DOG + yearlyTotals[firstYear].CAT;
const lastTotal = yearlyTotals[lastFullYear].DOG + yearlyTotals[lastFullYear].CAT;
const growthPct = Math.round(((lastTotal - firstTotal) / firstTotal) * 100);
const dogRatio = Math.round((yearlyTotals[lastFullYear].DOG / lastTotal) * 100);
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Background Preview</title>
  <link href="https://fonts.googleapis.com/css2?family=Intel+One+Mono:wght@400;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <Background />

  <div class="preview-content">
    <div class="accordion open" data-default-open>
      <div class="accordion-header" data-trigger>
        <span class="accordion-title">Pets of Toronto</span>
      </div>
      <div class="accordion-body">
        <p class="card-desc">
          A look at every licensed dog and cat in the city.
          Who they are, where they live, and what their
          names say about us.
        </p>
        <div class="stats">
          <p class="stat-row"><span class="stat-num">{totalDogs}</span> Total Dogs</p>
          <p class="stat-row"><span class="stat-num">{totalCats}</span> Total Cats</p>
          <p class="stat-row"><span class="stat-num">{uniqueBreeds.toLocaleString()}</span> Unique Breeds</p>
          <p class="stat-row"><span class="stat-num">{lunaCount.toLocaleString()}</span> Pets Named Luna</p>
        </div>
      </div>
    </div>

    <div class="accordion">
      <div class="accordion-header" data-trigger>
        <span class="accordion-title">Licensing Over Time</span>
      </div>
      <div class="accordion-body">
        <p class="card-desc">
          Toronto's pet licensing has grown <strong>{growthPct}%</strong> from {firstYear} to {lastFullYear},
          with dogs consistently making up about <strong>{dogRatio}%</strong> of all licenses.
        </p>
        <div id="licensing-chart"></div>
      </div>
    </div>

    <div class="accordion">
      <div class="accordion-header" data-trigger>
        <span class="accordion-title">Dog VS Cat Ownership</span>
      </div>
      <div class="accordion-body">
        <p class="card-desc">
          Which neighbourhoods lean dog, and which lean cat? Hover to see the breakdown by postal code.
        </p>
        <div id="glance-map"></div>
      </div>
    </div>
  </div>
</body>
</html>

<script>
  import { renderLicensingOverTime } from '../scripts/licensing-chart.js';
  import { renderMiniMap } from '../scripts/mini-map.js';
  import breedTrends from '../data/breed-trends.json';
  import fsaSummary from '../data/fsa-summary.json';
  import fsaGeo from '../data/fsa-geo.json';

  // Accordion logic
  document.querySelectorAll('[data-trigger]').forEach(header => {
    header.addEventListener('click', () => {
      const accordion = header.parentElement;
      const body = accordion.querySelector('.accordion-body');
      const isOpen = accordion.classList.contains('open');

      // Close all
      document.querySelectorAll('.accordion').forEach(a => {
        a.classList.remove('open');
        const b = a.querySelector('.accordion-body');
        if (b) b.style.maxHeight = '0';
      });

      // Open clicked if it wasn't already open
      if (!isOpen) {
        accordion.classList.add('open');
        body.style.maxHeight = body.scrollHeight + 'px';

        // Re-render charts after opening since they need a visible container
        const chartEl = body.querySelector('#licensing-chart');
        if (chartEl && !chartEl.querySelector('svg')) {
          renderLicensingOverTime('#licensing-chart', breedTrends);
        }
        const mapEl = body.querySelector('#glance-map');
        if (mapEl && !mapEl.querySelector('svg')) {
          renderMiniMap('#glance-map', fsaGeo, fsaSummary);
        }

        // Recalc max-height after chart renders
        requestAnimationFrame(() => {
          body.style.maxHeight = body.scrollHeight + 'px';
        });
      }
    });
  });

  // Open default
  const def = document.querySelector('[data-default-open]');
  if (def) {
    def.classList.add('open');
    const body = def.querySelector('.accordion-body');
    if (body) body.style.maxHeight = body.scrollHeight + 'px';
  }
</script>

<style is:global>
  .preview-content {
    position: relative;
    z-index: 1;
    padding: 59px 0 0 48px;
    display: flex;
    flex-direction: column;
    gap: 9px;
    max-width: 580px;
    font-family: 'Gantari', system-ui, sans-serif;
  }

  .accordion {
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 15px;
    transition: border-radius 0.3s ease;
  }

  .accordion.open {
    border-radius: 25px;
  }

  .accordion-header {
    display: flex;
    align-items: center;
    padding: 17px 33px 18px;
    cursor: pointer;
    user-select: none;
  }

  .accordion-title {
    font-size: 18px;
    font-weight: 600;
    color: #000;
    text-transform: uppercase;
    line-height: normal;
  }

  .accordion-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
    padding: 0 33px;
  }

  .accordion.open .accordion-body {
    padding-bottom: 28px;
  }

  .card-desc {
    font-size: 14px;
    font-weight: 400;
    color: #000;
    line-height: normal;
    margin-bottom: 14px;
  }

  .stats {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-row {
    font-size: 14px;
    font-weight: 700;
    color: #0f1532;
    line-height: normal;
  }

  .stat-num {
    display: inline-block;
    min-width: 7ch;
    text-align: right;
    margin-right: 1ch;
  }

  /* Chart/map inside accordion */
  #licensing-chart,
  #glance-map {
    min-width: 0;
    position: relative;
  }

  #licensing-chart svg,
  #glance-map svg {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
