---
import Base from '../layouts/Base.astro';
---

<Base title="Adopt a Pet | The Pets of Toronto">
  <section id="adopt">
    <div class="adopt-header">
      <h1 class="adopt-title">Ready to Meet Your Match?</h1>
      <p class="adopt-blurb">
        You've seen the data, now make it personal. Whether you're looking to adopt, foster, or just learn more, here's everything you need to bring a Toronto pet home.
      </p>
    </div>

    <div class="adopt-banner">
      <div class="banner-badge">Happening Now</div>
      <h2 class="banner-title">National Pet Adoption Week</h2>
      <p class="banner-dates">July 20 &ndash; 26, 2026</p>
      <p class="banner-desc">
        The City of Toronto is <span class="banner-highlight">waiving adoption fees for big dogs</span> (over 50 lbs) through July 26. PetSmart stores across the GTA are also hosting adoption events all week long with the #AdoptJoy campaign.
      </p>
    </div>

    <div class="adopt-grid adopt-grid-4">
      <div class="adopt-card">
        <div class="card-icon">🏠</div>
        <h3 class="card-title">Adopt from the City</h3>
        <p class="card-desc">
          Toronto Animal Services runs shelters across the city with dogs, cats, rabbits, and birds ready for a new home. Browse available pets online or visit in person.
        </p>
        <div class="card-details">
          <div class="detail-row">
            <span class="detail-label">Dogs</span>
            <span class="detail-value">$185 &ndash; $215 <span class="fee-note">(big dogs free until July 26!)</span></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Cats</span>
            <span class="detail-value">$75</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Rabbits</span>
            <span class="detail-value">$40</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">What to bring</span>
            <span class="detail-value">Valid ID with current address</span>
          </div>
        </div>
        <a href="https://www.toronto.ca/community-people/animals-pets/adopt-a-pet/" target="_blank" rel="noopener" class="card-link">Browse Available Pets &rarr;</a>
      </div>

      <div class="adopt-card">
        <div class="card-icon">🐾</div>
        <h3 class="card-title">Adopt at PetSmart</h3>
        <p class="card-desc">
          PetSmart Charities Canada partners with local rescue groups to host in-store adoption events. Over 400,000 pets have found homes through their program since 1999. That's about 50 pets a day.
        </p>
        <div class="card-details">
          <div class="detail-row">
            <span class="detail-label">When</span>
            <span class="detail-value">Adoption events all week (July 20&ndash;26)</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Where</span>
            <span class="detail-value">PetSmart locations across the GTA</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">How</span>
            <span class="detail-value">Walk in or browse online first</span>
          </div>
        </div>
        <a href="https://petsmartcharities.ca/adopt-a-pet/adoption-events" target="_blank" rel="noopener" class="card-link">Find an Event Near You &rarr;</a>
      </div>

      <div class="adopt-card foster-card">
        <div class="card-icon">💛</div>
        <h3 class="card-title">Foster a Pet</h3>
        <p class="card-desc">
          Not ready to commit forever? Fostering gives animals a safe home while they wait for adoption, and it frees up shelter space for more rescues. The city provides food, supplies, and veterinary care for foster animals.
        </p>
        <div class="card-details">
          <div class="detail-row">
            <span class="detail-label">Duration</span>
            <span class="detail-value">A few weeks to a few months</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Animals</span>
            <span class="detail-value">Dogs, cats, kittens, rabbits &amp; more</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Cost</span>
            <span class="detail-value">Free (supplies &amp; vet care provided)</span>
          </div>
        </div>
        <a href="https://www.toronto.ca/community-people/animals-pets/" target="_blank" rel="noopener" class="card-link">Learn About Fostering &rarr;</a>
      </div>

      <div class="adopt-card">
        <div class="card-icon">📞</div>
        <h3 class="card-title">Quick Links &amp; Contact</h3>
        <p class="card-desc">
          Everything else you might need, from licensing your new pet to finding a vet.
        </p>
        <div class="card-details">
          <div class="detail-row">
            <span class="detail-label">Toronto Animal Services</span>
            <span class="detail-value">416-338-PAWS (7297)</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">PetSmart Charities</span>
            <span class="detail-value">1-289-313-6400</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">City info line</span>
            <span class="detail-value">311</span>
          </div>
        </div>
        <div class="quick-links">
          <a href="https://24petconnect.com/TorontoAdoptablePets" target="_blank" rel="noopener" class="quick-link">Browse All City Pets</a>
          <a href="https://petsmartcharities.ca/adopt-a-pet" target="_blank" rel="noopener" class="quick-link">PetSmart Adoption Portal</a>
          <a href="https://www.toronto.ca/community-people/animals-pets/" target="_blank" rel="noopener" class="quick-link">Toronto Animals &amp; Pets Hub</a>
        </div>
      </div>
    </div>

    <div class="adopt-callout">
      <p>
        Adopting a pet is a commitment of up to 20 years. Make sure you're ready for daily exercise, veterinary costs, food, and licensing. If your situation changes, Toronto Animal Services accepts returns. Call 416-338-7297 to arrange.
      </p>
    </div>
  </section>
</Base>

<style>
  #adopt {
    text-align: left;
  }

  .adopt-header {
    margin-bottom: 2rem;
  }

  .adopt-title {
    font-size: 48px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 12px;
  }

  .adopt-blurb {
    font-size: 16px;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 48rem;
  }

  .adopt-banner {
    background: #FFF0EB;
    border: 2px solid var(--accent);
    border-radius: 1rem;
    padding: 1.5rem 2rem;
    margin-bottom: 1.5rem;
    max-width: 80rem;
    position: relative;
  }

  .banner-badge {
    display: inline-block;
    background: var(--accent);
    color: white;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.75rem;
    border-radius: 2rem;
    margin-bottom: 0.75rem;
  }

  .banner-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .banner-dates {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .banner-desc {
    font-size: 0.875rem;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .banner-highlight {
    font-weight: 600;
    color: var(--accent);
  }

  .adopt-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 80rem;
    margin-bottom: 1.5rem;
    align-items: stretch;
  }

  .adopt-card {
    background: white;
    border: 1px solid var(--gray-light);
    border-radius: 1rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .card-icon {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .card-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .card-desc {
    font-size: 0.8125rem;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .card-details {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .detail-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.375rem 0;
    border-bottom: 1px solid #f5f0e8;
    font-size: 0.8125rem;
  }

  .detail-row:last-child {
    border-bottom: none;
  }

  .detail-label {
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
  }

  .detail-value {
    font-weight: 300;
    color: var(--text-muted);
    text-align: right;
  }

  .fee-note {
    color: var(--accent);
    font-weight: 500;
    font-size: 0.75rem;
  }

  .card-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    margin-top: auto;
    transition: text-decoration 0.15s;
  }

  .card-link:hover {
    text-decoration: underline;
  }

  .quick-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .quick-link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    background: rgba(50, 116, 201, 0.08);
    border-radius: 0.5rem;
    transition: background 0.15s;
  }

  .quick-link:hover {
    background: rgba(50, 116, 201, 0.15);
    text-decoration: none;
  }

  .adopt-callout {
    background: var(--sidebar-bg);
    border: 1px solid var(--nav-active-bg);
    border-left: 4px solid var(--accent);
    border-radius: 0.5rem;
    padding: 0.875rem 1.25rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 80rem;
  }

  @media (max-width: 768px) {
    .adopt-title {
      font-size: 1.75rem;
    }
    .adopt-grid {
      grid-template-columns: 1fr;
    }
    .adopt-banner {
      padding: 1.25rem;
    }
  }
</style>
