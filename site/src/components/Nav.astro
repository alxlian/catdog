---
import metadata from '../data/metadata.json';
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
---

<nav id="sidebar-nav">
  <div class="sidebar-inner">
    <h1 class="sidebar-title">Pets TO</h1>

    <div class="nav-menu">
      <a href="/" class:list={["nav-item", "nav-pill", { active: isHome }]}>
        <svg class="nav-icon" viewBox="0 0 30 30" width="30" height="30" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="4" width="10" height="10" rx="2"/><rect x="16" y="4" width="10" height="10" rx="2"/><rect x="4" y="16" width="10" height="10" rx="2"/><rect x="16" y="16" width="10" height="10" rx="2"/></svg>
        <span>At a Glance</span>
      </a>

      <a href="/neighbourhoods" class:list={["nav-item", { active: currentPath.startsWith('/neighbourhoods') }]}>
        <svg class="nav-icon" viewBox="0 0 30 30" width="30" height="30" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 26V10l8-6 8 6v16"/><path d="M12 26V18h4v8"/><path d="M20 14l6-4v16"/></svg>
        <span>Neighbourhoods</span>
      </a>

      <a href="/breeds" class:list={["nav-item", { active: currentPath.startsWith('/breeds') }]}>
        <svg class="nav-icon" viewBox="0 0 30 30" width="30" height="30" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 22l4-8 4 4 4-12 4 16"/><circle cx="8" cy="22" r="2"/></svg>
        <span>Breed Trends</span>
      </a>

      <a href="/names" class:list={["nav-item", { active: currentPath.startsWith('/names') }]}>
        <svg class="nav-icon" viewBox="0 0 30 30" width="30" height="30" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 8h20M5 15h14M5 22h18"/><circle cx="25" cy="15" r="3"/></svg>
        <span>Pet Names</span>
      </a>

      <a href="/typical" class:list={["nav-item", { active: currentPath.startsWith('/typical') }]}>
        <svg class="nav-icon" viewBox="0 0 30 30" width="30" height="30" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="18" width="6" height="8"/><rect x="12" y="10" width="6" height="16"/><rect x="21" y="4" width="6" height="22"/></svg>
        <span>By the Numbers</span>
      </a>

      <a href="/rarity" class:list={["nav-item", { active: currentPath.startsWith('/rarity') }]}>
        <svg class="nav-icon" viewBox="0 0 30 30" width="30" height="30" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 4l3.09 6.26L25 11.27l-5 4.87 1.18 6.88L15 19.77l-6.18 3.25L10 16.14l-5-4.87 6.91-1.01L15 4z"/></svg>
        <span>How Rare Is Your Pet?</span>
      </a>
    </div>

    <a href="/adopt" class="nav-item adopt-link">
      <svg class="nav-icon" viewBox="0 0 30 30" width="30" height="30" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="4" width="10" height="10" rx="2"/><rect x="16" y="4" width="10" height="10" rx="2"/><rect x="4" y="16" width="10" height="10" rx="2"/><rect x="16" y="16" width="10" height="10" rx="2"/></svg>
      <span>Adopt!</span>
    </a>

    <div class="sidebar-footer">
      <p>Data last processed: {new Date(metadata.generated_at).toLocaleDateString('en-CA')}</p>
      <p>Covering license years {metadata.year_range[0]}&ndash;{metadata.year_range[1]}</p>
    </div>
  </div>

  <!-- Mobile toggle -->
  <button class="nav-toggle" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<style>
  #sidebar-nav {
    position: fixed;
    top: 0;
    left: 0;
    width: var(--sidebar-width);
    height: 100vh;
    background: var(--sidebar-bg);
    border-right: 1px solid var(--sidebar-border);
    z-index: 50;
  }

  .sidebar-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 48px 28px 32px;
  }

  .sidebar-title {
    font-size: 36px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 64px;
    line-height: 1.2;
  }

  .nav-menu {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 10px 24px;
    border-radius: 20px;
    font-size: 15px;
    font-weight: 300;
    color: var(--text);
    text-decoration: none;
    transition: background 0.15s;
  }

  .nav-item span {
    display: inline-block;
    min-width: max-content;
  }

  .nav-item:hover {
    font-weight: 500;
    text-decoration: none;
  }

  .nav-item.active {
    background: var(--nav-active-bg);
    font-weight: 500;
  }

  .nav-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .adopt-link {
    margin-top: auto;
    background: var(--accent-light);
    border: 1px solid var(--accent);
    color: var(--accent);
    margin-bottom: 40px;
    width: 100%;
  }

  .adopt-link:hover {
    background: var(--accent);
    color: white;
    text-decoration: none;
  }

  .sidebar-footer {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .nav-toggle { display: none; }

  @media (max-width: 768px) {
    #sidebar-nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      width: 100%;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--sidebar-border);
    }
    .sidebar-inner {
      display: none;
      padding: 1rem 1.5rem;
    }
    .sidebar-inner.open { display: flex; height: auto; }
    .sidebar-title {
      font-size: 1.25rem;
      margin-bottom: 1rem;
    }
    .adopt-link { width: 100%; margin-top: 1rem; }
    .sidebar-footer { margin-top: 1rem; }
    .nav-toggle {
      display: block;
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: none;
      border: none;
      cursor: pointer;
      z-index: 51;
    }
    .nav-toggle span {
      display: block;
      width: 1.25rem;
      height: 2px;
      background: var(--text);
      margin: 4px 0;
    }
  }
</style>
