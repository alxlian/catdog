---
import metadata from '../data/metadata.json';
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
---

<nav id="sidebar-nav">
  <div class="sidebar-inner">
    <div class="sidebar-title-row">
      <h1 class="sidebar-title">Pets TO</h1>
      <span class="toronto-clock" id="toronto-clock"></span>
    </div>

    <div class="nav-menu">
      <a href="/" class:list={["nav-item", "nav-pill", { active: isHome }]}>
        <img class="nav-icon" src="/assets/at-a-glance-icon.png" alt="" />
        <span>At a Glance</span>
      </a>

      <a href="/neighbourhoods" class:list={["nav-item", { active: currentPath.startsWith('/neighbourhoods') }]}>
        <img class="nav-icon" src="/assets/neighbourhood-icon.png" alt="" />
        <span>Neighbourhoods</span>
      </a>

      <a href="/breeds" class:list={["nav-item", { active: currentPath.startsWith('/breeds') }]}>
        <img class="nav-icon" src="/assets/breed-icon.png" alt="" />
        <span>Breeds</span>
      </a>

      <a href="/names" class:list={["nav-item", { active: currentPath.startsWith('/names') }]}>
        <img class="nav-icon" src="/assets/pet-icon.png" alt="" />
        <span>Names</span>
      </a>

      <a href="/typical" class:list={["nav-item", { active: currentPath.startsWith('/typical') }]}>
        <img class="nav-icon" src="/assets/numbers-icon.png" alt="" />
        <span>By the Numbers</span>
      </a>

      <a href="/rarity" class:list={["nav-item", { active: currentPath.startsWith('/rarity') }]}>
        <img class="nav-icon" src="/assets/stars-icon.png" alt="" />
        <span>How Rare Is Your Pet?</span>
      </a>
    </div>

    <a href="/adopt" class="nav-item adopt-link">
      <img class="nav-icon" src="/assets/pet-icon.png" alt="" />
      <span>Adopt!</span>
    </a>

    <div class="bg-toggle" id="bg-toggle">
      <button class="bg-btn" data-bg="sunrise">Sunrise</button>
      <button class="bg-btn" data-bg="day">Day</button>
      <button class="bg-btn" data-bg="sunset">Sunset</button>
      <button class="bg-btn" data-bg="night">Night</button>
    </div>

    <div class="sidebar-footer">
      <p>Data last processed: {new Date(metadata.generated_at).toLocaleDateString('en-CA')}</p>
      <p>Covering license years {metadata.year_range[0]}&ndash;{metadata.year_range[1]}</p>
    </div>
  </div>

  <!-- Mobile toggle -->
  <button class="nav-toggle" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<style>
  #sidebar-nav {
    position: fixed;
    top: 25px;
    left: 27px;
    width: var(--sidebar-width);
    height: calc(100vh - 50px);
    background: rgba(255, 252, 242, 0.25);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid #828282;
    border-radius: 25px;
    z-index: 50;
    overflow: hidden;
  }

  .sidebar-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 48px 40px 33px;
  }

  .sidebar-title-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 64px;
  }

  .sidebar-title {
    font-size: 36px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.2;
  }

  .toronto-clock {
    font-size: 14px;
    font-weight: 400;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .nav-menu {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 10px 24px;
    border-radius: 20px;
    font-size: 15px;
    font-weight: 300;
    color: var(--text);
    text-decoration: none;
    transition: background 0.15s;
  }

  .nav-item span {
    display: inline-block;
    min-width: max-content;
  }

  .nav-item:hover {
    background: rgba(255, 255, 255, 0.3);
    font-weight: 500;
    text-decoration: none;
  }

  .nav-item.active {
    background: rgba(255, 255, 255, 0.35);
    font-weight: 500;
  }

  .nav-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .adopt-link {
    margin-top: auto;
    background: var(--accent-light);
    border: 1px solid var(--accent);
    color: var(--accent);
    margin-bottom: 40px;
    width: 100%;
  }

  .adopt-link:hover {
    background: var(--accent);
    color: white;
    text-decoration: none;
  }

  .sidebar-footer {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .bg-toggle {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
  }

  .bg-btn {
    padding: 4px 10px;
    border: 1px solid rgba(130, 130, 130, 0.5);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.2);
    font-family: var(--font);
    font-size: 11px;
    font-weight: 500;
    color: var(--text);
    cursor: pointer;
    transition: background 0.15s;
  }

  .bg-btn:hover {
    background: rgba(255, 255, 255, 0.4);
  }

  .bg-btn.active {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }

  .nav-toggle { display: none; }

  @media (max-width: 768px) {
    #sidebar-nav {
      position: fixed;
      top: 10px;
      left: 10px;
      right: 10px;
      width: auto;
      height: auto;
      border-radius: 20px;
    }
    .sidebar-inner {
      display: none;
      padding: 1rem 1.5rem;
    }
    .sidebar-inner.open { display: flex; height: auto; }
    .sidebar-title {
      font-size: 1.25rem;
      margin-bottom: 1rem;
    }
    .adopt-link { width: 100%; margin-top: 1rem; }
    .sidebar-footer { margin-top: 1rem; }
    .nav-toggle {
      display: block;
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: none;
      border: none;
      cursor: pointer;
      z-index: 51;
    }
    .nav-toggle span {
      display: block;
      width: 1.25rem;
      height: 2px;
      background: var(--text);
      margin: 4px 0;
    }
  }
</style>
