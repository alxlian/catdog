---
import metadata from '../data/metadata.json';
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
---

<nav id="sidebar-nav">
  <div class="sidebar-inner">
    <h1 class="sidebar-title">Pets TO</h1>

    <div class="nav-menu">
      <a href="/" class:list={["nav-item", "nav-pill", { active: isHome }]}>
        <img class="nav-icon" src="/assets/at-a-glance-icon.png" alt="" />
        <span>At a Glance</span>
      </a>

      <a href="/neighbourhoods" class:list={["nav-item", { active: currentPath.startsWith('/neighbourhoods') }]}>
        <img class="nav-icon" src="/assets/neighbourhood-icon.png" alt="" />
        <span>Neighbourhoods</span>
      </a>

      <a href="/breeds" class:list={["nav-item", { active: currentPath.startsWith('/breeds') }]}>
        <img class="nav-icon" src="/assets/breed-icon.png" alt="" />
        <span>Breeds</span>
      </a>

      <a href="/names" class:list={["nav-item", { active: currentPath.startsWith('/names') }]}>
        <img class="nav-icon" src="/assets/pet-icon.png" alt="" />
        <span>Names</span>
      </a>

      <a href="/typical" class:list={["nav-item", { active: currentPath.startsWith('/typical') }]}>
        <img class="nav-icon" src="/assets/numbers-icon.png" alt="" />
        <span>By the Numbers</span>
      </a>

      <a href="/rarity" class:list={["nav-item", { active: currentPath.startsWith('/rarity') }]}>
        <img class="nav-icon" src="/assets/stars-icon.png" alt="" />
        <span>How Rare Is Your Pet?</span>
      </a>
    </div>

    <a href="/adopt" class="nav-item adopt-link">
      <img class="nav-icon" src="/assets/pet-icon.png" alt="" />
      <span>Adopt!</span>
    </a>

    <div class="sidebar-footer">
      <p>Data last processed: {new Date(metadata.generated_at).toLocaleDateString('en-CA')}</p>
      <p>Covering license years {metadata.year_range[0]}&ndash;{metadata.year_range[1]}</p>
    </div>
  </div>

  <!-- Mobile toggle -->
  <button class="nav-toggle" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<style>
  #sidebar-nav {
    position: fixed;
    top: 0;
    left: 0;
    width: var(--sidebar-width);
    height: 100vh;
    background: var(--sidebar-bg);
    border-right: 1px solid var(--sidebar-border);
    z-index: 50;
  }

  .sidebar-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 48px 28px 32px;
  }

  .sidebar-title {
    font-size: 36px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 64px;
    line-height: 1.2;
  }

  .nav-menu {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 10px 24px;
    border-radius: 20px;
    font-size: 15px;
    font-weight: 300;
    color: var(--text);
    text-decoration: none;
    transition: background 0.15s;
  }

  .nav-item span {
    display: inline-block;
    min-width: max-content;
  }

  .nav-item:hover {
    font-weight: 500;
    text-decoration: none;
  }

  .nav-item.active {
    background: var(--nav-active-bg);
    font-weight: 500;
  }

  .nav-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .adopt-link {
    margin-top: auto;
    background: var(--accent-light);
    border: 1px solid var(--accent);
    color: var(--accent);
    margin-bottom: 40px;
    width: 100%;
  }

  .adopt-link:hover {
    background: var(--accent);
    color: white;
    text-decoration: none;
  }

  .sidebar-footer {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .nav-toggle { display: none; }

  @media (max-width: 768px) {
    #sidebar-nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      width: 100%;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--sidebar-border);
    }
    .sidebar-inner {
      display: none;
      padding: 1rem 1.5rem;
    }
    .sidebar-inner.open { display: flex; height: auto; }
    .sidebar-title {
      font-size: 1.25rem;
      margin-bottom: 1rem;
    }
    .adopt-link { width: 100%; margin-top: 1rem; }
    .sidebar-footer { margin-top: 1rem; }
    .nav-toggle {
      display: block;
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: none;
      border: none;
      cursor: pointer;
      z-index: 51;
    }
    .nav-toggle span {
      display: block;
      width: 1.25rem;
      height: 2px;
      background: var(--text);
      margin: 4px 0;
    }
  }
</style>
