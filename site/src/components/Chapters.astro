---
import citywide from '../data/citywide.json';
import fsaSummary from '../data/fsa-summary.json';
import breedList from '../data/breed-list.json';
import { toTitleCase } from '../scripts/utils.js';

// Compute highlight stats
const neighbourhoodCount = Object.keys(fsaSummary).length;

// Most cat-populated neighbourhood by count
const entries = Object.entries(fsaSummary) as [string, any][];
const mostCats = entries.reduce((best, [, d]) =>
  d.cat_count > (best?.cat_count || 0) ? d : best, entries[0][1]);

// Unique breeds
const uniqueBreeds = new Set(breedList.map((e: any) => e.breed)).size;

const chapters = [
  {
    href: '/neighbourhoods',
    stat: neighbourhoodCount.toString(),
    label: 'Neighbourhoods',
    blurb: `Every corner of Toronto has its own pet personality. ${mostCats.neighbourhood} is secretly cat country with ${mostCats.cat_count.toLocaleString()} licensed felines.`,
  },
  {
    href: '/breeds',
    stat: uniqueBreeds.toLocaleString(),
    label: 'Breeds Tracked',
    blurb: `From Labs to Chinese Cresteds — see who's rising, who's fading, and who's holding steady across the city.`,
  },
  {
    href: '/typical',
    stat: '2.4:1',
    label: 'Dog-to-Cat Ratio',
    blurb: `For every licensed cat, there are roughly 2.4 dogs. Meet the most typical Toronto pet — and the one-of-a-kind breeds that break the mould.`,
  },
  {
    href: '/rarity',
    stat: citywide.top_name.DOG.name ? toTitleCase(citywide.top_name.DOG.name) : '?',
    label: '#1 Pet Name',
    blurb: `${toTitleCase(citywide.top_name.DOG.name)} reigns supreme for dogs and cats alike. Look up your pet and see how you stack up.`,
  },
];
---

<section id="chapters">
  <h2>Go Deeper</h2>
  <p class="chapters-blurb">There's a lot more to Toronto's pets than the headlines.</p>

  <div class="chapters-grid">
    {chapters.map((ch) => (
      <a href={ch.href} class="chapter-card">
        <div class="chapter-stat">{ch.stat}</div>
        <div class="chapter-label">{ch.label}</div>
        <p class="chapter-desc">{ch.blurb}</p>
        <span class="chapter-cta">Explore &rarr;</span>
      </a>
    ))}
  </div>
</section>

<style>
  #chapters {
    padding-top: 2.5rem;
    padding-bottom: 3rem;
  }

  #chapters h2 {
    font-size: 28px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 8px;
  }

  .chapters-blurb {
    font-size: 15px;
    font-weight: 300;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .chapters-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .chapter-card {
    background: var(--sidebar-bg);
    border: 1px solid var(--nav-active-bg);
    border-radius: 16px;
    padding: 28px 28px 24px;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
    display: flex;
    flex-direction: column;
  }

  .chapter-card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 20px rgba(235, 94, 40, 0.1);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .chapter-stat {
    font-size: 40px;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 4px;
  }

  .chapter-label {
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .chapter-desc {
    font-size: 14px;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
  }

  .chapter-desc strong {
    color: var(--accent);
    font-weight: 500;
  }

  .chapter-cta {
    font-size: 14px;
    font-weight: 500;
    color: var(--accent);
    margin-top: 16px;
    transition: gap 0.15s;
  }

  .chapter-card:hover .chapter-cta {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .chapters-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
