---
import citywide from '../data/citywide.json';
import breedList from '../data/breed-list.json';
import names from '../data/names.json';

const totalDogs = citywide.species_split.DOG.toLocaleString();
const totalCats = citywide.species_split.CAT.toLocaleString();

// Compute unique breeds
const uniqueBreeds = new Set(breedList.map((e: any) => e.breed)).size;

// Compute pets named Luna
let lunaCount = 0;
for (const species of Object.values(names) as any[]) {
  if (species['LUNA']) {
    for (const entry of species['LUNA']) {
      lunaCount += entry.count;
    }
  }
}
---

<section id="hero">
  <h1 class="hero-title">Cats &amp; Dogs of Toronto</h1>
  <p class="hero-blurb">
    A look at every licensed dog and cat in the city. Who they are, where they live,
    and what their names say about us. Built from City of Toronto open data.
  </p>

  <div class="pet-tag-row">
    <div class="pet-tag">
      <div class="tag-ring"></div>
      <div class="tag-connector"></div>
      <div class="tag-body">
        <span class="tag-number">{totalDogs}</span>
        <span class="tag-label">Total Dogs</span>
      </div>
    </div>
    <div class="pet-tag">
      <div class="tag-ring"></div>
      <div class="tag-connector"></div>
      <div class="tag-body">
        <span class="tag-number">{totalCats}</span>
        <span class="tag-label">Total Cats</span>
      </div>
    </div>
    <div class="pet-tag">
      <div class="tag-ring"></div>
      <div class="tag-connector"></div>
      <div class="tag-body">
        <span class="tag-number">{uniqueBreeds.toLocaleString()}</span>
        <span class="tag-label">Unique Breeds</span>
      </div>
    </div>
    <div class="pet-tag">
      <div class="tag-ring"></div>
      <div class="tag-connector"></div>
      <div class="tag-body">
        <span class="tag-number">{lunaCount.toLocaleString()}</span>
        <span class="tag-label">Pets Named Luna</span>
      </div>
    </div>
  </div>
</section>

<style>
  #hero {
    padding: 80px clamp(1rem, 3vw, 3rem) calc(2rem + 50px);
  }

  .hero-title {
    font-size: 48px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 12px;
  }

  .hero-blurb {
    font-size: 16px;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 540px;
    margin-bottom: 48px;
  }

  .pet-tag-row {
    display: flex;
    gap: 40px;
  }

  .pet-tag {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 170px;
  }

  .tag-ring {
    width: 26px;
    height: 26px;
    border: 3.5px solid #F5C133;
    border-radius: 50%;
    background: var(--bg);
    position: relative;
    z-index: 2;
    box-shadow: 0 1px 3px rgba(232, 168, 23, 0.2);
  }

  .tag-connector {
    width: 3.5px;
    height: 10px;
    background: #F5C133;
    margin-top: -2px;
    position: relative;
    z-index: 1;
    border-radius: 2px;
  }

  .tag-body {
    width: 170px;
    height: 170px;
    border-radius: 50%;
    background:
      radial-gradient(circle at 35% 30%, rgba(255, 255, 230, 0.6) 0%, transparent 45%),
      radial-gradient(circle at 50% 50%, #FFD95C 0%, #F5C133 50%, #E8A817 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 6px 16px rgba(232, 168, 23, 0.25),
      0 2px 4px rgba(0, 0, 0, 0.06),
      inset 0 2px 6px rgba(255, 255, 255, 0.5);
    margin-top: -4px;
    position: relative;
    z-index: 0;
    border: 2px solid #F5C133;
    cursor: pointer;
    transform-origin: top center;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .tag-body:hover {
    transform: scale(1.03);
    box-shadow:
      0 8px 24px rgba(232, 168, 23, 0.3),
      0 3px 6px rgba(0, 0, 0, 0.08),
      inset 0 2px 6px rgba(255, 255, 255, 0.5);
  }

  .tag-body::before {
    content: '';
    position: absolute;
    top: 14%;
    left: 22%;
    width: 28%;
    height: 20%;
    background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.5) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .pet-tag.shaking .tag-body {
    animation: tag-shake 0.6s ease-in-out;
  }

  @keyframes tag-shake {
    0% { transform: rotate(0deg); }
    15% { transform: rotate(8deg); }
    30% { transform: rotate(-6deg); }
    45% { transform: rotate(4deg); }
    60% { transform: rotate(-3deg); }
    75% { transform: rotate(1.5deg); }
    100% { transform: rotate(0deg); }
  }

  .tag-number {
    font-size: 34px;
    font-weight: 600;
    color: var(--tag-text);
    line-height: 1;
  }

  .tag-label {
    font-size: 13px;
    font-weight: 400;
    color: var(--tag-text);
    text-transform: uppercase;
    margin-top: 6px;
    letter-spacing: 0.02em;
  }

  @media (max-width: 1200px) {
    #hero { padding: 60px clamp(1rem, 3vw, 3rem) 2.5rem; }
  }

  @media (max-width: 1024px) {
    #hero { padding: 50px clamp(1rem, 3vw, 3rem) 2rem; }
    .pet-tag-row { gap: 24px; }
    .pet-tag { width: 140px; }
    .tag-body { width: 140px; height: 140px; }
    .tag-number { font-size: 26px; }
    .tag-label { font-size: 11px; }
  }

  @media (max-width: 768px) {
    #hero { padding: 2rem 1rem; }
    .hero-title { font-size: 1.75rem; margin-bottom: 8px; }
    .hero-blurb { font-size: 14px; margin-bottom: 2rem; }
    .pet-tag-row {
      flex-wrap: wrap;
      gap: 1.5rem;
      justify-content: center;
    }
    .pet-tag { width: 120px; }
    .tag-body { width: 120px; height: 120px; }
    .tag-number { font-size: 22px; }
    .tag-label { font-size: 9px; }
    .tag-ring { width: 20px; height: 20px; border-width: 3px; }
    .tag-connector { width: 3px; height: 8px; }
  }
</style>

<script>
  document.querySelectorAll('.pet-tag').forEach(tag => {
    tag.addEventListener('click', () => {
      tag.classList.remove('shaking');
      void tag.offsetWidth;
      tag.classList.add('shaking');
    });
    tag.addEventListener('animationend', () => {
      tag.classList.remove('shaking');
    });
  });
</script>
