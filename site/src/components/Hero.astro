---
import citywide from '../data/citywide.json';

const total = citywide.total_licenses.toLocaleString();
const dogCount = citywide.species_split.DOG.toLocaleString();
const catCount = citywide.species_split.CAT.toLocaleString();
---

<section id="hero">
  <div class="hero-content">
    <h1>The Pets of Toronto</h1>
    <p class="hero-subtitle">A data portrait of {total} licensed dogs and cats across the city's neighbourhoods.</p>
    <div class="hero-stats">
      <div class="stat-card">
        <div class="stat-value dog-color">{dogCount}</div>
        <div class="stat-label">Licensed Dogs</div>
      </div>
      <div class="stat-card">
        <div class="stat-value cat-color">{catCount}</div>
        <div class="stat-label">Licensed Cats</div>
      </div>
    </div>
    <div id="species-donut" class="donut-container"></div>
  </div>
  <nav class="hero-nav">
    <a href="/neighbourhoods" class="hero-nav-card">
      <span class="hero-nav-icon">🗺</span>
      <span class="hero-nav-label">Neighbourhoods</span>
    </a>
    <a href="/breeds" class="hero-nav-card">
      <span class="hero-nav-icon">📈</span>
      <span class="hero-nav-label">Breed Trends</span>
    </a>
    <a href="/names" class="hero-nav-card">
      <span class="hero-nav-icon">🏷</span>
      <span class="hero-nav-label">Names</span>
    </a>
    <a href="/rarity" class="hero-nav-card">
      <span class="hero-nav-icon">✨</span>
      <span class="hero-nav-label">How Rare?</span>
    </a>
  </nav>
</section>

<script>
  import { renderDonut } from '../scripts/donut.js';
  import citywide from '../data/citywide.json';
  renderDonut('#species-donut', citywide.species_split);
</script>

<style>
  #hero {
    text-align: center;
    padding: 6rem 1.5rem 4rem;
  }
  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--gray);
    margin-top: 0.75rem;
    max-width: 36rem;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 2.5rem;
  }
  .hero-stats .stat-card { min-width: 10rem; }
  .donut-container {
    margin: 2.5rem auto 0;
    max-width: 16rem;
  }
  .hero-nav {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 3rem;
    flex-wrap: wrap;
  }
  .hero-nav-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.25rem 1.5rem;
    background: white;
    border: 1px solid var(--gray-light);
    border-radius: 0.75rem;
    text-decoration: none;
    color: var(--navy);
    transition: all 0.2s;
    min-width: 8rem;
  }
  .hero-nav-card:hover {
    text-decoration: none;
    border-color: var(--navy);
    box-shadow: 0 4px 12px rgba(26, 43, 74, 0.1);
    transform: translateY(-2px);
  }
  .hero-nav-icon { font-size: 1.5rem; }
  .hero-nav-label { font-size: 0.8125rem; font-weight: 600; }

  @media (max-width: 768px) {
    #hero { padding: 3rem 1rem 2rem; }
    .hero-stats { flex-direction: column; align-items: center; }
    .hero-nav { gap: 0.75rem; }
    .hero-nav-card { min-width: 6rem; padding: 1rem; }
  }
</style>
