---
import names from '../data/names.json';
import { toTitleCase } from '../scripts/utils.js';

const dogNames = (names as any).DOG || {};
const catNames = (names as any).CAT || {};
const totalUnique = new Set([...Object.keys(dogNames), ...Object.keys(catNames)]).size;

// Top dog name
const dogTotals = Object.entries(dogNames)
  .map(([name, entries]: [string, any]) => ({ name, total: entries.reduce((s: number, e: any) => s + e.count, 0) }))
  .sort((a, b) => b.total - a.total);
const topDogName = dogTotals[0];

// Top cat name
const catTotals = Object.entries(catNames)
  .map(([name, entries]: [string, any]) => ({ name, total: entries.reduce((s: number, e: any) => s + e.count, 0) }))
  .sort((a, b) => b.total - a.total);
const topCatName = catTotals[0];

// Shared names count
const sharedCount = Object.keys(dogNames).filter(n => catNames[n]).length;
---

<section id="names">
  <div class="names-hero">
    <div class="names-header">
      <h1 class="names-title">What's in a Name?</h1>
      <p class="names-blurb">
        Toronto's pet owners have come up with {totalUnique.toLocaleString()} unique names — and yet,
        <strong>{toTitleCase(topDogName.name)}</strong> still leads the pack for dogs with {topDogName.total.toLocaleString()} all-time registrations.
        On the cat side, <strong>{toTitleCase(topCatName.name)}</strong> takes the crown at {topCatName.total.toLocaleString()}.
        {sharedCount} names cross the species line.
      </p>
      <div class="names-callout">
        <strong>Note:</strong> The City of Toronto only publishes a ranked list of the most popular pet names each year — not a complete registry of every name.
        Names that fall outside the top ranks aren't included, so totals here reflect popularity rankings rather than exact citywide counts.
      </div>
    </div>
    <div class="card names-trend-card">
      <h3 class="card-heading">Name Trends <span class="card-heading-note">current top 5 by yearly rank</span></h3>
      <div id="name-trend-chart"></div>
      <div id="name-trend-legend" class="trend-legend"></div>
    </div>
  </div>

  <div class="names-row">
    <div>
      <div class="section-heading-row">
        <h3 class="section-heading">Top 20 Names <span class="section-heading-note">all-time registrations</span></h3>
        <div class="btn-group" id="names-species-toggle">
          <button class="toggle-btn active" data-value="DOG">Dogs</button>
          <button class="toggle-btn" data-value="CAT">Cats</button>
        </div>
      </div>
      <div id="names-leaderboard"></div>
    </div>
    <div class="card">
      <h3 class="card-heading">Crossover Stars</h3>
      <p class="card-desc">Names that work for both sides — and how popular they are with each.</p>
      <div id="crossover-names"></div>
    </div>
  </div>

  <div class="names-row">
    <div class="card">
      <h3 class="card-heading">Dogs Only</h3>
      <p class="card-desc">Names you'll never hear at the cat clinic.</p>
      <div id="dog-exclusive"></div>
    </div>
    <div class="card">
      <h3 class="card-heading">Cats Only</h3>
      <p class="card-desc">Strictly feline territory — no dogs allowed.</p>
      <div id="cat-exclusive"></div>
    </div>
  </div>
</section>

<script>
  import { renderNamesPage } from '../scripts/name-chart.js';
  import names from '../data/names.json';
  renderNamesPage(names);
</script>

<style>
  #names {
    text-align: left;
  }

  .names-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
    margin-bottom: 1.5rem;
  }

  .names-header {
    margin-bottom: 0;
  }

  .names-trend-card {
    min-width: 0;
    overflow: visible;
  }

  .names-title {
    font-size: 48px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 12px;
  }

  .names-blurb {
    font-size: 16px;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 48rem;
  }

  .names-blurb strong {
    color: var(--accent);
    font-weight: 500;
  }

  .names-callout {
    background: var(--sidebar-bg);
    border: 1px solid var(--nav-active-bg);
    border-left: 4px solid var(--accent);
    border-radius: 0.5rem;
    padding: 0.875rem 1.25rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-top: 1rem;
    margin-bottom: 0;
  }

  .names-callout strong {
    color: var(--accent);
    font-weight: 600;
  }

  .section-heading-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1.75rem;
  }

  .section-heading-row .section-heading {
    margin-bottom: 0;
  }

  .btn-group {
    display: inline-flex;
    border: 1px solid var(--gray-light);
    border-radius: 0.5rem;
    overflow: hidden;
    background: white;
  }

  .btn-group button {
    padding: 0.5rem 1.25rem;
    border: none;
    border-right: 1px solid var(--gray-light);
    background: transparent;
    font-family: var(--font);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    color: var(--gray);
    transition: all 0.2s;
    white-space: nowrap;
  }

  .btn-group button:last-child {
    border-right: none;
  }

  .btn-group button.active {
    background: var(--accent);
    color: white;
  }

  .btn-group button:hover:not(.active) {
    background: var(--gray-light);
  }

  .names-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 80rem;
    align-items: start;
    margin-bottom: 1.5rem;
  }

  .card {
    background: white;
    border: 1px solid var(--gray-light);
    border-radius: 1rem;
    padding: 1.25rem;
  }

  .card-heading {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .section-heading {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .section-heading-note {
    font-weight: 400;
    color: var(--text-muted);
    font-size: 0.75rem;
  }

  .card-heading-note {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: var(--text-muted);
    font-size: 0.75rem;
  }

  .card-desc {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .trend-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    font-size: 0.75rem;
    margin-top: 0.5rem;
  }

  #name-trend-chart svg {
    width: 100%;
    height: auto;
  }

  @media (max-width: 1024px) {
    .names-hero {
      grid-template-columns: 1fr;
    }
    .names-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .names-title {
      font-size: 1.75rem;
    }
  }
</style>
